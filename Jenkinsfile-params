pipeline {
    agent any

    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'stg', 'prod'],
            description: 'Select the environment'
        )
    }

    stages {
        stage('Hello World') {
            steps {
                echo "Hello World from trigger ${params.ENVIRONMENT}"
            }
        }

        stage('Hello Jenkins') {
            steps {
                echo "Hello Jenkins from ${params.ENVIRONMENT}"
            }
        }
    }

    post {
        always {
            echo 'This block runs regardless of the build outcome.'
        }
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed!'
            mail to: 'ahmedkhater2611@gmail.com',
                 subject: "Failed Pipeline: ${env.JOB_NAME} [Build #${env.BUILD_NUMBER}]",
                 body: "The pipeline failed for environment: ${params.ENVIRONMENT}.\n\nView the build details here: ${env.BUILD_URL}"
        }
        aborted {
            echo 'Pipeline was aborted!'
            mail to: 'ahmedkhater2611@gmail.com',
                 subject: "Aborted Pipeline: ${env.JOB_NAME} [Build #${env.BUILD_NUMBER}]",
                 body: "The pipeline was aborted for environment: ${params.ENVIRONMENT}.\n\nView the build details here: ${env.BUILD_URL}"
        }
    }
}
