```groovy
pipeline {
    agent any

    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'stg', 'prod'],
            description: 'Select the environment'
        )
    }

    stages {

        stage('Hello World') {
            steps {
                echo "Hello World from trigger ${params.ENVIRONMENT}"
            }
        }

        stage('Hello Jenkins') {
            steps {
                echo "Hello Jenkins from ${params.ENVIRONMENT}"
            }
        }

        // stage used ONLY for testing failure email
        stage('Fail Stage') {
            steps {
                error 'This build failed intentionally for email testing'
            }
        }

    }

    post {
        success {
            echo 'Pipeline completed successfully!'
        }

        failure {
            echo 'Pipeline failed! Sending email notification...'

            emailext(
                to: 'ayatmoatamed05@gmail.com',
                subject: "❌ Jenkins Build Failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
Hello Ayat,

Your Jenkins pipeline has FAILED.

📌 Job Name: ${env.JOB_NAME}
📌 Build Number: ${env.BUILD_NUMBER}
📌 Environment: ${params.ENVIRONMENT}
📌 Build URL: ${env.BUILD_URL}

Please check the logs.

Regards,
Jenkins
"""
            )
        }
    }
}
```
